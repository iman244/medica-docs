<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_J-ONBOARD" targetNamespace="http://medica/flows">
  <bpmn:collaboration id="Collab_J-ONBOARD"><bpmn:participant id="Pool_J-ONBOARD" name="Onboarding &amp; Eligibility (J-ONBOARD)" processRef="Proc_J-ONBOARD" /></bpmn:collaboration>
  <bpmn:process id="Proc_J-ONBOARD" isExecutable="false">
    <bpmn:laneSet id="LS_J-ONBOARD">
      <bpmn:lane id="Lane_J-ONBOARD_Patient" name="Patient">
        <bpmn:flowNodeRef>s0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_bmi</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_signup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_otp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_kyc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_kyc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_profile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_quest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_elig</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_elig</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_consent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_conf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_otp</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-ONBOARD_Ops___CS" name="Ops / CS">
        <bpmn:flowNodeRef>r_kyc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_pause</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-ONBOARD_Doctor" name="Doctor">
        <bpmn:flowNodeRef>r_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_no</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="s0" name="Visitor lands">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t_bmi" name="BMI + public eligibility (MF-A.H2/H3)">
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_signup" name="Sign up + verify OTP (PF-A.H1/H2)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_otp" name="OTP valid?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_kyc" name="Verify identity / KYC (PF-A.H5)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_kyc" name="KYC pass?">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_profile" name="Profile, health, history, labs, address (PF-B.H1-H5)">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_quest" name="Eligibility questionnaire (PF-B.H6)">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_elig" name="Compute eligibility (PF-B.H7)">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_elig" name="Eligible?">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_consent" name="Sign consent (PF-B.H8)">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_conf" name="Confirmations (PF-B.H9)">
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_done" name="Onboarded -&gt; subscribe">
      <bpmn:incoming>f19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_otp" name="Resend OTP (R-RESEND-OTP)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_kyc" name="Manual KYC review (R-KYC-REVIEW)">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_pause" name="Onboarding paused">
      <bpmn:incoming>f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_review" name="Paid doctor review (R-ELIG-REVIEW)">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_no" name="Not enrolled">
      <bpmn:incoming>f17</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f0" sourceRef="s0" targetRef="t_bmi" />
    <bpmn:sequenceFlow id="f1" sourceRef="t_bmi" targetRef="t_signup" />
    <bpmn:sequenceFlow id="f2" sourceRef="t_signup" targetRef="g_otp" />
    <bpmn:sequenceFlow id="f3" name="valid" sourceRef="g_otp" targetRef="t_kyc" />
    <bpmn:sequenceFlow id="f4" name="invalid" sourceRef="g_otp" targetRef="r_otp" />
    <bpmn:sequenceFlow id="f5" sourceRef="r_otp" targetRef="t_kyc" />
    <bpmn:sequenceFlow id="f6" sourceRef="t_kyc" targetRef="g_kyc" />
    <bpmn:sequenceFlow id="f7" name="pass" sourceRef="g_kyc" targetRef="t_profile" />
    <bpmn:sequenceFlow id="f8" name="fail" sourceRef="g_kyc" targetRef="r_kyc" />
    <bpmn:sequenceFlow id="f9" name="verified" sourceRef="r_kyc" targetRef="t_profile" />
    <bpmn:sequenceFlow id="f10" name="still failing" sourceRef="r_kyc" targetRef="e_pause" />
    <bpmn:sequenceFlow id="f11" sourceRef="t_profile" targetRef="t_quest" />
    <bpmn:sequenceFlow id="f12" sourceRef="t_quest" targetRef="t_elig" />
    <bpmn:sequenceFlow id="f13" sourceRef="t_elig" targetRef="g_elig" />
    <bpmn:sequenceFlow id="f14" name="eligible" sourceRef="g_elig" targetRef="t_consent" />
    <bpmn:sequenceFlow id="f15" name="borderline / ineligible" sourceRef="g_elig" targetRef="r_review" />
    <bpmn:sequenceFlow id="f16" name="approved" sourceRef="r_review" targetRef="t_consent" />
    <bpmn:sequenceFlow id="f17" name="not approved" sourceRef="r_review" targetRef="e_no" />
    <bpmn:sequenceFlow id="f18" sourceRef="t_consent" targetRef="t_conf" />
    <bpmn:sequenceFlow id="f19" sourceRef="t_conf" targetRef="e_done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dg_J-ONBOARD"><bpmndi:BPMNPlane id="Pl_J-ONBOARD" bpmnElement="Collab_J-ONBOARD">
    <bpmndi:BPMNShape id="Pool_J-ONBOARD_di" bpmnElement="Pool_J-ONBOARD" isHorizontal="true"><dc:Bounds x="150" y="50" width="2606" height="940" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-ONBOARD_Patient_di" bpmnElement="Lane_J-ONBOARD_Patient" isHorizontal="true"><dc:Bounds x="180" y="60" width="2576" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-ONBOARD_Ops___CS_di" bpmnElement="Lane_J-ONBOARD_Ops___CS" isHorizontal="true"><dc:Bounds x="180" y="360" width="2576" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-ONBOARD_Doctor_di" bpmnElement="Lane_J-ONBOARD_Doctor" isHorizontal="true"><dc:Bounds x="180" y="660" width="2576" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="s0_di" bpmnElement="s0"><dc:Bounds x="240" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_bmi_di" bpmnElement="t_bmi"><dc:Bounds x="440" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_signup_di" bpmnElement="t_signup"><dc:Bounds x="640" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_otp_di" bpmnElement="g_otp"><dc:Bounds x="840" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_kyc_di" bpmnElement="t_kyc"><dc:Bounds x="1040" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_kyc_di" bpmnElement="g_kyc"><dc:Bounds x="1240" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_profile_di" bpmnElement="t_profile"><dc:Bounds x="1440" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_quest_di" bpmnElement="t_quest"><dc:Bounds x="1640" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_elig_di" bpmnElement="t_elig"><dc:Bounds x="1840" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_elig_di" bpmnElement="g_elig"><dc:Bounds x="2040" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_consent_di" bpmnElement="t_consent"><dc:Bounds x="2240" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_conf_di" bpmnElement="t_conf"><dc:Bounds x="2440" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_done_di" bpmnElement="e_done"><dc:Bounds x="2640" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_otp_di" bpmnElement="r_otp"><dc:Bounds x="840" y="220" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_kyc_di" bpmnElement="r_kyc"><dc:Bounds x="1240" y="520" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_pause_di" bpmnElement="e_pause"><dc:Bounds x="1440" y="534" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_review_di" bpmnElement="r_review"><dc:Bounds x="2040" y="820" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_no_di" bpmnElement="e_no"><dc:Bounds x="2240" y="834" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="f0_di" bpmnElement="f0"><di:waypoint x="276" y="147" /><di:waypoint x="440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1"><di:waypoint x="610" y="147" /><di:waypoint x="640" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2"><di:waypoint x="810" y="147" /><di:waypoint x="840" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3"><di:waypoint x="890" y="147" /><di:waypoint x="1040" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4"><di:waypoint x="865" y="172" /><di:waypoint x="925" y="220" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5"><di:waypoint x="925" y="220" /><di:waypoint x="1125" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6"><di:waypoint x="1210" y="147" /><di:waypoint x="1240" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7"><di:waypoint x="1290" y="147" /><di:waypoint x="1440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8"><di:waypoint x="1265" y="172" /><di:waypoint x="1325" y="520" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9"><di:waypoint x="1325" y="520" /><di:waypoint x="1525" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10"><di:waypoint x="1410" y="552" /><di:waypoint x="1440" y="552" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11"><di:waypoint x="1610" y="147" /><di:waypoint x="1640" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12"><di:waypoint x="1810" y="147" /><di:waypoint x="1840" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13"><di:waypoint x="2010" y="147" /><di:waypoint x="2040" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f14_di" bpmnElement="f14"><di:waypoint x="2090" y="147" /><di:waypoint x="2240" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f15_di" bpmnElement="f15"><di:waypoint x="2065" y="172" /><di:waypoint x="2125" y="820" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f16_di" bpmnElement="f16"><di:waypoint x="2125" y="820" /><di:waypoint x="2325" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f17_di" bpmnElement="f17"><di:waypoint x="2210" y="852" /><di:waypoint x="2240" y="852" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f18_di" bpmnElement="f18"><di:waypoint x="2410" y="147" /><di:waypoint x="2440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f19_di" bpmnElement="f19"><di:waypoint x="2610" y="147" /><di:waypoint x="2640" y="147" /></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>