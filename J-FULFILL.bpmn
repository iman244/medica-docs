<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_J-FULFILL_home_visit_fulfillment" targetNamespace="http://medica/flows">
  <bpmn:collaboration id="Collab_J-FULFILL_home_visit_fulfillment"><bpmn:participant id="Pool_J-FULFILL_home_visit_fulfillment" name="Home-Visit Fulfillment (J-FULFILL)" processRef="Proc_J-FULFILL_home_visit_fulfillment" /></bpmn:collaboration>
  <bpmn:process id="Proc_J-FULFILL_home_visit_fulfillment" isExecutable="false">
    <bpmn:laneSet id="LS_J-FULFILL_home_visit_fulfillment">
      <bpmn:lane id="Lane_J-FULFILL_home_visit_fulfillment_Ops" name="Ops">
        <bpmn:flowNodeRef>s0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_slot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_geo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_geo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_geo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-FULFILL_home_visit_fulfillment_Pharmacy" name="Pharmacy">
        <bpmn:flowNodeRef>t_disp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_disp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_stock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_resched1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-FULFILL_home_visit_fulfillment_Nurse" name="Nurse">
        <bpmn:flowNodeRef>t_nav</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_gps</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_gps</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_cc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_cc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_pre</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_vial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_vial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_sign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_sign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_online</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_gps</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_cc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_block</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_vial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_sign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_off</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-FULFILL_home_visit_fulfillment_Patient" name="Patient">
        <bpmn:flowNodeRef>t_verify</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_home</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_admin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_home</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_resched2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="s0" name="Dose due / Rx active">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t_slot" name="Schedule into patient's weekly slot — PF-E.H9 / F-181 (day &amp; time only; ops assigns the nurse)">
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_geo" name="Geocode address (OP-B.H1)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_geo" name="Geocoded?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_route" name="Optimize route within the slot (OP-B.H2)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_disp" name="Dispense to nurse (PH-A.H5)">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_disp" name="In stock &amp; cold-chain OK?">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_nav" name="Travel &amp; navigate (NF-A.H3)">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_route" name="Route available?">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_verify" name="Verify nurse, confirm time (PF-E.H2/H3)">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_home" name="Patient home?">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_gps" name="GPS check-in (NF-A.H4)">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_gps" name="GPS OK?">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_cc" name="Record cold-chain temp (NF-A.H6)">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_cc" name="Cold-chain OK?">
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f24</bpmn:outgoing>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_pre" name="Pre-injection assessment (NF-A.H7)">
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_vial" name="Scan vial &amp; site (NF-A.H8)">
      <bpmn:incoming>f27</bpmn:incoming>
      <bpmn:outgoing>f28</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_vial" name="Vial match?">
      <bpmn:incoming>f28</bpmn:incoming>
      <bpmn:outgoing>f29</bpmn:outgoing>
      <bpmn:outgoing>f30</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_admin" name="Administer; patient confirms (PF-E.H4/H5)">
      <bpmn:incoming>f29</bpmn:incoming>
      <bpmn:incoming>f31</bpmn:incoming>
      <bpmn:outgoing>f32</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_sign" name="Patient confirms by SMS code (NF-A.H9)">
      <bpmn:incoming>f32</bpmn:incoming>
      <bpmn:outgoing>f33</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_sign" name="SMS confirmed?">
      <bpmn:incoming>f33</bpmn:incoming>
      <bpmn:outgoing>f34</bpmn:outgoing>
      <bpmn:outgoing>f35</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_submit" name="Submit visit (NF-A.H10)">
      <bpmn:incoming>f34</bpmn:incoming>
      <bpmn:incoming>f36</bpmn:incoming>
      <bpmn:outgoing>f37</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_online" name="Online?">
      <bpmn:incoming>f37</bpmn:incoming>
      <bpmn:outgoing>f38</bpmn:outgoing>
      <bpmn:outgoing>f39</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e_done" name="Visit fulfilled">
      <bpmn:incoming>f38</bpmn:incoming>
      <bpmn:incoming>f40</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_geo" name="Manual map-pin (R-GEOCODE-MANUAL)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_stock" name="Stock-out / hub breach → R-STOCKOUT / R-HUB-QUARANTINE">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_resched1" name="Re-dispatch / reschedule">
      <bpmn:incoming>f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_route" name="Manual route / last-known (R-TRACK-FALLBACK)">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_home" name="Abort &amp; reschedule (R-RESCHEDULE)">
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_resched2" name="Visit rescheduled">
      <bpmn:incoming>f18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_gps" name="Supervisor override + audit (R-GPS-OVERRIDE)">
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_cc" name="Block, abort, replacement order (R-REPLACE)">
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_block" name="Visit blocked; replacement dispatched">
      <bpmn:incoming>f26</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_vial" name="Rescan; else replacement (R-VIAL-RESCAN → R-REPLACE)">
      <bpmn:incoming>f30</bpmn:incoming>
      <bpmn:outgoing>f31</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_sign" name="Resend SMS / manual confirm (R-OTP-RECEIPT)">
      <bpmn:incoming>f35</bpmn:incoming>
      <bpmn:outgoing>f36</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_off" name="Capture offline; sync later (R-OFFLINE-CAPTURE)">
      <bpmn:incoming>f39</bpmn:incoming>
      <bpmn:outgoing>f40</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="f0" sourceRef="s0" targetRef="t_slot" />
    <bpmn:sequenceFlow id="f1" sourceRef="t_slot" targetRef="t_geo" />
    <bpmn:sequenceFlow id="f2" sourceRef="t_geo" targetRef="g_geo" />
    <bpmn:sequenceFlow id="f3" name="yes" sourceRef="g_geo" targetRef="t_route" />
    <bpmn:sequenceFlow id="f4" name="no" sourceRef="g_geo" targetRef="r_geo" />
    <bpmn:sequenceFlow id="f5" sourceRef="r_geo" targetRef="t_route" />
    <bpmn:sequenceFlow id="f6" sourceRef="t_route" targetRef="t_disp" />
    <bpmn:sequenceFlow id="f7" sourceRef="t_disp" targetRef="g_disp" />
    <bpmn:sequenceFlow id="f8" name="yes" sourceRef="g_disp" targetRef="t_nav" />
    <bpmn:sequenceFlow id="f9" name="no" sourceRef="g_disp" targetRef="r_stock" />
    <bpmn:sequenceFlow id="f10" sourceRef="r_stock" targetRef="e_resched1" />
    <bpmn:sequenceFlow id="f11" sourceRef="t_nav" targetRef="g_route" />
    <bpmn:sequenceFlow id="f12" name="yes" sourceRef="g_route" targetRef="t_verify" />
    <bpmn:sequenceFlow id="f13" name="no" sourceRef="g_route" targetRef="r_route" />
    <bpmn:sequenceFlow id="f14" sourceRef="r_route" targetRef="t_verify" />
    <bpmn:sequenceFlow id="f15" sourceRef="t_verify" targetRef="g_home" />
    <bpmn:sequenceFlow id="f16" name="yes" sourceRef="g_home" targetRef="t_gps" />
    <bpmn:sequenceFlow id="f17" name="no" sourceRef="g_home" targetRef="r_home" />
    <bpmn:sequenceFlow id="f18" sourceRef="r_home" targetRef="e_resched2" />
    <bpmn:sequenceFlow id="f19" sourceRef="t_gps" targetRef="g_gps" />
    <bpmn:sequenceFlow id="f20" name="yes" sourceRef="g_gps" targetRef="t_cc" />
    <bpmn:sequenceFlow id="f21" name="no" sourceRef="g_gps" targetRef="r_gps" />
    <bpmn:sequenceFlow id="f22" sourceRef="r_gps" targetRef="t_cc" />
    <bpmn:sequenceFlow id="f23" sourceRef="t_cc" targetRef="g_cc" />
    <bpmn:sequenceFlow id="f24" name="OK" sourceRef="g_cc" targetRef="t_pre" />
    <bpmn:sequenceFlow id="f25" name="breach" sourceRef="g_cc" targetRef="r_cc" />
    <bpmn:sequenceFlow id="f26" sourceRef="r_cc" targetRef="e_block" />
    <bpmn:sequenceFlow id="f27" sourceRef="t_pre" targetRef="t_vial" />
    <bpmn:sequenceFlow id="f28" sourceRef="t_vial" targetRef="g_vial" />
    <bpmn:sequenceFlow id="f29" name="match" sourceRef="g_vial" targetRef="t_admin" />
    <bpmn:sequenceFlow id="f30" name="mismatch" sourceRef="g_vial" targetRef="r_vial" />
    <bpmn:sequenceFlow id="f31" sourceRef="r_vial" targetRef="t_admin" />
    <bpmn:sequenceFlow id="f32" sourceRef="t_admin" targetRef="t_sign" />
    <bpmn:sequenceFlow id="f33" sourceRef="t_sign" targetRef="g_sign" />
    <bpmn:sequenceFlow id="f34" name="yes" sourceRef="g_sign" targetRef="t_submit" />
    <bpmn:sequenceFlow id="f35" name="no" sourceRef="g_sign" targetRef="r_sign" />
    <bpmn:sequenceFlow id="f36" sourceRef="r_sign" targetRef="t_submit" />
    <bpmn:sequenceFlow id="f37" sourceRef="t_submit" targetRef="g_online" />
    <bpmn:sequenceFlow id="f38" name="yes" sourceRef="g_online" targetRef="e_done" />
    <bpmn:sequenceFlow id="f39" name="no" sourceRef="g_online" targetRef="r_off" />
    <bpmn:sequenceFlow id="f40" sourceRef="r_off" targetRef="e_done" />
  </bpmn:process>
