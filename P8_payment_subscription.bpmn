<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://medica/bpmn" id="DEF_P8_payment_subscription"><bpmn:collaboration id="C_P8_payment_subscription"><bpmn:participant id="PT_P8_payment_subscription" name="Payment &amp; Subscription Lifecycle" processRef="PR_P8_payment_subscription" /></bpmn:collaboration><bpmn:process id="PR_P8_payment_subscription" isExecutable="false"><bpmn:laneSet id="LS_P8_payment_subscription"><bpmn:lane id="pat" name="Patient"><bpmn:flowNodeRef>s</bpmn:flowNodeRef><bpmn:flowNodeRef>pay</bpmn:flowNodeRef><bpmn:flowNodeRef>ret</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="sys" name="System"><bpmn:flowNodeRef>rsv</bpmn:flowNodeRef><bpmn:flowNodeRef>chg</bpmn:flowNodeRef><bpmn:flowNodeRef>g</bpmn:flowNodeRef><bpmn:flowNodeRef>act</bpmn:flowNodeRef><bpmn:flowNodeRef>eok</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="bank" name="Bank Gateway"><bpmn:flowNodeRef>proc</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="s" name="Checkout (STEP-3A-02)"><bpmn:outgoing>F_s_pay</bpmn:outgoing></bpmn:startEvent><bpmn:userTask id="pay" name="Confirm payment"><bpmn:incoming>F_s_pay</bpmn:incoming><bpmn:incoming>F_ret_pay</bpmn:incoming><bpmn:outgoing>F_pay_proc</bpmn:outgoing></bpmn:userTask><bpmn:startEvent id="rsv" name="Renewal due (timer)"><bpmn:outgoing>F_rsv_chg</bpmn:outgoing></bpmn:startEvent><bpmn:serviceTask id="chg" name="Attempt charge"><bpmn:incoming>F_rsv_chg</bpmn:incoming><bpmn:outgoing>F_chg_g</bpmn:outgoing></bpmn:serviceTask><bpmn:task id="proc" name="Process payment"><bpmn:incoming>F_pay_proc</bpmn:incoming><bpmn:outgoing>F_proc_g</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="g" name="Result?"><bpmn:incoming>F_chg_g</bpmn:incoming><bpmn:incoming>F_proc_g</bpmn:incoming><bpmn:outgoing>F_g_act</bpmn:outgoing><bpmn:outgoing>F_g_ret</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:serviceTask id="act" name="Activate / renew subscription"><bpmn:incoming>F_g_act</bpmn:incoming><bpmn:outgoing>F_act_eok</bpmn:outgoing></bpmn:serviceTask><bpmn:userTask id="ret" name="Failure + retry (RFLOW-12)"><bpmn:incoming>F_g_ret</bpmn:incoming><bpmn:outgoing>F_ret_pay</bpmn:outgoing></bpmn:userTask><bpmn:endEvent id="eok" name="Subscription active"><bpmn:incoming>F_act_eok</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="F_s_pay" sourceRef="s" targetRef="pay" name="" /><bpmn:sequenceFlow id="F_pay_proc" sourceRef="pay" targetRef="proc" name="" /><bpmn:sequenceFlow id="F_rsv_chg" sourceRef="rsv" targetRef="chg" name="" /><bpmn:sequenceFlow id="F_chg_g" sourceRef="chg" targetRef="g" name="" /><bpmn:sequenceFlow id="F_proc_g" sourceRef="proc" targetRef="g" name="" /><bpmn:sequenceFlow id="F_g_act" sourceRef="g" targetRef="act" name="success" /><bpmn:sequenceFlow id="F_g_ret" sourceRef="g" targetRef="ret" name="fail" /><bpmn:sequenceFlow id="F_act_eok" sourceRef="act" targetRef="eok" name="" /><bpmn:sequenceFlow id="F_ret_pay" sourceRef="ret" targetRef="pay" name="" /></bpmn:process><bpmndi:BPMNDiagram id="DI_P8_payment_subscription"><bpmndi:BPMNPlane id="PL_P8_payment_subscription" bpmnElement="C_P8_payment_subscription"><bpmndi:BPMNShape id="S_PT_P8_payment_subscription" bpmnElement="PT_P8_payment_subscription" isHorizontal="true"><dc:Bounds x="180" y="80" width="1160" height="535" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_pat" bpmnElement="pat" isHorizontal="true"><dc:Bounds x="210" y="80" width="1130" height="210" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_sys" bpmnElement="sys" isHorizontal="true"><dc:Bounds x="210" y="290" width="1130" height="210" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_bank" bpmnElement="bank" isHorizontal="true"><dc:Bounds x="210" y="500" width="1130" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_s" bpmnElement="s"><dc:Bounds x="262" y="119" width="36" height=