<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_J-SIDEEFFECT" targetNamespace="http://medica/flows">
  <bpmn:collaboration id="Collab_J-SIDEEFFECT"><bpmn:participant id="Pool_J-SIDEEFFECT" name="Urgent Side-Effect Escalation (J-SIDEEFFECT)" processRef="Proc_J-SIDEEFFECT" /></bpmn:collaboration>
  <bpmn:process id="Proc_J-SIDEEFFECT" isExecutable="false">
    <bpmn:laneSet id="LS_J-SIDEEFFECT">
      <bpmn:lane id="Lane_J-SIDEEFFECT_Patient" name="Patient">
        <bpmn:flowNodeRef>s0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_urg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_res</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_log</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-SIDEEFFECT_Ops" name="Ops">
        <bpmn:flowNodeRef>t_alert</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_mon</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-SIDEEFFECT_Doctor" name="Doctor">
        <bpmn:flowNodeRef>t_rev</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_disp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_emerg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_advise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_queue</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="s0" name="Report side effect (PF-F.H1)">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="g_urg" name="Urgent? [clinical]">
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_alert" name="Must-alert doctor + ops (R-CLINICAL-ESC)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_mon" name="Monitor + assign reviewer (OP-C.H1)">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_rev" name="Doctor reviews (emergency visit / message)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_disp" name="Disposition?">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e_emerg" name="Emergency visit">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:endEvent>
    <bpmn:endEvent id="e_res" name="Resolved">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_advise" name="Advise / adjust">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_queue" name="Queue for routine review">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_log" name="Logged / advised">
      <bpmn:incoming>f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f0" sourceRef="s0" targetRef="g_urg" />
    <bpmn:sequenceFlow id="f1" name="urgent" sourceRef="g_urg" targetRef="t_alert" />
    <bpmn:sequenceFlow id="f2" sourceRef="t_alert" targetRef="t_mon" />
    <bpmn:sequenceFlow id="f3" sourceRef="t_mon" targetRef="t_rev" />
    <bpmn:sequenceFlow id="f4" sourceRef="t_rev" targetRef="g_disp" />
    <bpmn:sequenceFlow id="f5" name="emergency" sourceRef="g_disp" targetRef="e_emerg" />
    <bpmn:sequenceFlow id="f6" name="manage" sourceRef="g_disp" targetRef="t_advise" />
    <bpmn:sequenceFlow id="f7" sourceRef="t_advise" targetRef="e_res" />
    <bpmn:sequenceFlow id="f8" sourceRef="e_emerg" targetRef="e_res" />
    <bpmn:sequenceFlow id="f9" name="not urgent" sourceRef="g_urg" targetRef="t_queue" />
    <bpmn:sequenceFlow id="f10" sourceRef="t_queue" targetRef="e_log" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dg_J-SIDEEFFECT"><bpmndi:BPMNPlane id="Pl_J-SIDEEFFECT" bpmnElement="Collab_J-SIDEEFFECT">
    <bpmndi:BPMNShape id="Pool_J-SIDEEFFECT_di" bpmnElement="Pool_J-SIDEEFFECT" isHorizontal="true"><dc:Bounds x="150" y="50" width="1606" height="940" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-SIDEEFFECT_Patient_di" bpmnElement="Lane_J-SIDEEFFECT_Patient" isHorizontal="true"><dc:Bounds x="180" y="60" width="1576" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-SIDEEFFECT_Ops_di" bpmnElement="Lane_J-SIDEEFFECT_Ops" isHorizontal="true"><dc:Bounds x="180" y="360" width="1576" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-SIDEEFFECT_Doctor_di" bpmnElement="Lane_J-SIDEEFFECT_Doctor" isHorizontal="true"><dc:Bounds x="180" y="660" width="1576" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="s0_di" bpmnElement="s0"><dc:Bounds x="240" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_urg_di" bpmnElement="g_urg"><dc:Bounds x="440" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_alert_di" bpmnElement="t_alert"><dc:Bounds x="640" y="415" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_mon_di" bpmnElement="t_mon"><dc:Bounds x="840" y="415" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_rev_di" bpmnElement="t_rev"><dc:Bounds x="1040" y="715" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_disp_di" bpmnElement="g_disp"><dc:Bounds x="1240" y="722" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_emerg_di" bpmnElement="e_emerg"><dc:Bounds x="1440" y="729" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_res_di" bpmnElement="e_res"><dc:Bounds x="1640" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_advise_di" bpmnElement="t_advise"><dc:Bounds x="1440" y="820" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_queue_di" bpmnElement="t_queue"><dc:Bounds x="640" y="820" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_log_di" bpmnElement="e_log"><dc:Bounds x="840" y="234" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="f0_di" bpmnElement="f0"><di:waypoint x="276" y="147" /><di:waypoint x="440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1"><di:waypoint x="465" y="172" /><di:waypoint x="725" y="415" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2"><di:waypoint x="810" y="447" /><di:waypoint x="840" y="447" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3"><di:waypoint x="925" y="479" /><di:waypoint x="1125" y="715" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4"><di:waypoint x="1210" y="747" /><di:waypoint x="1240" y="747" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5"><di:waypoint x="1290" y="747" /><di:waypoint x="1440" y="747" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6"><di:waypoint x="1265" y="772" /><di:waypoint x="1525" y="820" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7"><di:waypoint x="1525" y="820" /><di:waypoint x="1658" y="165" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8"><di:waypoint x="1458" y="729" /><di:waypoint x="1658" y="165" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9"><di:waypoint x="465" y="172" /><di:waypoint x="725" y="820" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10"><di:waypoint x="725" y="820" /><di:waypoint x="858" y="270" /></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>