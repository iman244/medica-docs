<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://medica/bpmn" id="DEF_P6_batch_recall"><bpmn:collaboration id="C_P6_batch_recall"><bpmn:participant id="PT_P6_batch_recall" name="Batch Recall (RFLOW-02)" processRef="PR_P6_batch_recall" /></bpmn:collaboration><bpmn:process id="PR_P6_batch_recall" isExecutable="false"><bpmn:laneSet id="LS_P6_batch_recall"><bpmn:lane id="adm" name="Admin"><bpmn:flowNodeRef>s</bpmn:flowNodeRef><bpmn:flowNodeRef>flag</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="sys" name="System"><bpmn:flowNodeRef>idf</bpmn:flowNodeRef><bpmn:flowNodeRef>g</bpmn:flowNodeRef><bpmn:flowNodeRef>e</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="phm" name="Pharmacy"><bpmn:flowNodeRef>quar</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="clin" name="Clinician"><bpmn:flowNodeRef>follow</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="pat" name="Patient"><bpmn:flowNodeRef>notif</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="s" name="Recall issued"><bpmn:outgoing>F_s_flag</bpmn:outgoing></bpmn:startEvent><bpmn:userTask id="flag" name="Flag batch recalled"><bpmn:incoming>F_s_flag</bpmn:incoming><bpmn:outgoing>F_flag_idf</bpmn:outgoing></bpmn:userTask><bpmn:serviceTask id="idf" name="Identify affected vials + patients"><bpmn:incoming>F_flag_idf</bpmn:incoming><bpmn:outgoing>F_idf_g</bpmn:outgoing></bpmn:serviceTask><bpmn:exclusiveGateway id="g" name="Vial state?"><bpmn:incoming>F_idf_g</bpmn:incoming><bpmn:outgoing>F_g_quar</bpmn:outgoing><bpmn:outgoing>F_g_follow</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:userTask id="quar" name="Quarantine + replace"><bpmn:incoming>F_g_quar</bpmn:incoming><bpmn:outgoing>F_quar_notif</bpmn:outgoing></bpmn:userTask><bpmn:userTask id="follow" name="Clinical follow-up [clinical] · patient comms"><bpmn:incoming>F_g_follow</bpmn:incoming><bpmn:outgoing>F_follow_notif</bpmn:outgoing></bpmn:userTask><bpmn:task id="notif" name="Recall notification"><bpmn:incoming>F_quar_notif</bpmn:incoming><bpmn:incoming>F_follow_notif</bpmn:incoming><bpmn:outgoing>F_notif_e</bpmn:outgoing></bpmn:task><bpmn:endEvent id="e" name="Recall handled"><bpmn:incoming>F_notif_e</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="F_s_flag" sourceRef="s" targetRef="flag" name="" /><bpmn:sequenceFlow id="F_flag_idf" sourceRef="flag" targetRef="idf" name="" /><bpmn:sequenceFlow id="F_idf_g" sourceRef="idf" targetRef="g" name="" /><bpmn:sequenceFlow id="F_g_quar" sourceRef="g" targetRef="quar" name="in stock / scheduled" /><bpmn:sequenceFlow id="F_g_follow" sourceRef="g" targetRef="follow" name="already administered" /><bpmn:sequenceFlow id="F_quar_notif" sourceRef="quar" targetRef="notif" name="" /><bpmn:sequenceFlow id="F_follow_notif" sourceRef="follow" targetRef="notif" name="" /><bpmn:sequenceFlow id="F_notif_e" sourceRef="notif" targetRef="e" name="" /></bpmn:process><bpmndi:BPMNDiagram id="DI_P6_batch_recall"><bpmndi:BPMNPlane id="PL_P6_batch_recall" bpmnElement="C_P6_batch_recall"><bpmndi:BPMNShape id="S_PT_P6_batch_recall" bpmnElement="PT_P6_batch_recall" isHorizontal="true"><dc:Bounds x="180" y="80" width="1330" height="670" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_adm" bpmnElement="adm" isHorizontal="true"><dc:Bounds x="210" y="80" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_sys" bpmnElement="sys" isHorizontal="true"><dc:Bounds x="210" y="195" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_phm" bpmnElement="phm" isHorizontal="true"><dc:Bounds x="210" y="310" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_clin" bpmnElement="clin" isHorizontal="true"><dc:Bounds x="210" y="425" width="1300" height="210" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_pat" bpmnElement="pat" isHorizontal="true"><dc:Bounds x="210" y="635" width="1300" he