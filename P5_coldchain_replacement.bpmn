<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://medica/bpmn" id="DEF_P5_coldchain_replacement"><bpmn:collaboration id="C_P5_coldchain_replacement"><bpmn:participant id="PT_P5_coldchain_replacement" name="Cold-Chain Breach → Replacement (RFLOW-01)" processRef="PR_P5_coldchain_replacement" /></bpmn:collaboration><bpmn:process id="PR_P5_coldchain_replacement" isExecutable="false"><bpmn:laneSet id="LS_P5_coldchain_replacement"><bpmn:lane id="nur" name="Nurse"><bpmn:flowNodeRef>s</bpmn:flowNodeRef><bpmn:flowNodeRef>mark</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="ops" name="Ops / Admin"><bpmn:flowNodeRef>repl</bpmn:flowNodeRef><bpmn:flowNodeRef>resch</bpmn:flowNodeRef><bpmn:flowNodeRef>e</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="phm" name="Pharmacy"><bpmn:flowNodeRef>disp</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="pat" name="Patient"><bpmn:flowNodeRef>notif</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="s" name="Cold-chain breach (from P4)"><bpmn:outgoing>F_s_mark</bpmn:outgoing></bpmn:startEvent><bpmn:userTask id="mark" name="Abort visit · mark stock exposed (STEP-5-03)"><bpmn:incoming>F_s_mark</bpmn:incoming><bpmn:outgoing>F_mark_repl</bpmn:outgoing></bpmn:userTask><bpmn:serviceTask id="repl" name="Create replacement order + SLA (RFLOW-01)"><bpmn:incoming>F_mark_repl</bpmn:incoming><bpmn:outgoing>F_repl_disp</bpmn:outgoing></bpmn:serviceTask><bpmn:userTask id="disp" name="Dispatch replacement vial"><bpmn:incoming>F_repl_disp</bpmn:incoming><bpmn:outgoing>F_disp_resch</bpmn:outgoing></bpmn:userTask><bpmn:serviceTask id="resch" name="Reassign nurse / reschedule"><bpmn:incoming>F_disp_resch</bpmn:incoming><bpmn:outgoing>F_resch_notif</bpmn:outgoing></bpmn:serviceTask><bpmn:task id="notif" name="Patient notified of reschedule"><bpmn:incoming>F_resch_notif</bpmn:incoming><bpmn:outgoing>F_notif_e</bpmn:outgoing></bpmn:task><bpmn:endEvent id="e" name="Replacement delivered → re-enter P4"><bpmn:incoming>F_notif_e</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="F_s_mark" sourceRef="s" targetRef="mark" name="" /><bpmn:sequenceFlow id="F_mark_repl" sourceRef="mark" targetRef="repl" name="" /><bpmn:sequenceFlow id="F_repl_disp" sourceRef="repl" targetRef="disp" name="" /><bpmn:sequenceFlow id="F_disp_resch" sourceRef="disp" targetRef="resch" name="" /><bpmn:sequenceFlow id="F_resch_notif" sourceRef="resch" targetRef="notif" name="" /><bpmn:sequenceFlow id="F_notif_e" sourceRef="notif" targetRef="e" name="" /></bpmn:process><bpmndi:BPMNDiagram id="DI_P5_coldchain_replacement"><bpmndi:BPMNPlane id="PL_P5_coldchain_replacement" bpmnElement="C_P5_coldchain_replacement"><bpmndi:BPMNShape id="S_PT_P5_coldchain_replacement" bpmnElement="PT_P5_coldchain_replacement" isHorizontal="true"><dc:Bounds x="180" y="80" width="1330" height="460" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_nur" bpmnElement="nur" isHorizontal="true"><dc:Bounds x="210" y="80" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_ops" bpmnElement="ops" isHorizontal="true"><dc:Bounds x="210" y="195" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_phm" bpmnElement="phm" isHorizontal="true"><dc:Bounds x="210" y="310" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_pat" bpmnElement="pat" isHorizontal="true"><dc:Bounds x="210" y="425" width="1300" height="115" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_s" bpmnElement="s"><dc:Bounds x="262" y="119" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="237" y="157" width="86" height="14"/></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_mark" bpmnElement="mark"><dc:Bounds x="395" y="100" width="110" height="74" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="S_repl" bpmnElement="repl"><dc:Bounds x="565" y="215" width="110" hei