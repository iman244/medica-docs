<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_J-SUBSCRIBE" targetNamespace="http://medica/flows">
  <bpmn:collaboration id="Collab_J-SUBSCRIBE"><bpmn:participant id="Pool_J-SUBSCRIBE" name="Subscription &amp; Payment Lifecycle (J-SUBSCRIBE)" processRef="Proc_J-SUBSCRIBE" /></bpmn:collaboration>
  <bpmn:process id="Proc_J-SUBSCRIBE" isExecutable="false">
    <bpmn:laneSet id="LS_J-SUBSCRIBE">
      <bpmn:lane id="Lane_J-SUBSCRIBE_Patient" name="Patient">
        <bpmn:flowNodeRef>s0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_view</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_active</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_renew</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_active</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_payretry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_nosub</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_cancel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_ended</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_react</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-SUBSCRIBE_Finance___Ops" name="Finance / Ops">
        <bpmn:flowNodeRef>r_dunning</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_grace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_charge</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="s0" name="Decide to subscribe">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t_view" name="View packages (PF-C.H1)">
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_pay" name="Purchase &amp; pay (PF-C.H2)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_pay" name="Payment OK?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_active" name="Subscription active (PF-C.H3)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f14</bpmn:outgoing>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_renew" name="Renewal charged?">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e_active" name="Active / renewed">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:incoming>f19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_payretry" name="Retry / switch / wallet (R-PAY-RETRY)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_nosub" name="No subscription">
      <bpmn:incoming>f6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t_cancel" name="Cancel + exit interview (PF-C.H4)">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_ended" name="Subscription ended">
      <bpmn:incoming>f15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_dunning" name="Past-due dunning (R-DUNNING)">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_grace" name="Paid in grace?">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="r_react" name="Reactivate [clinical] (R-REACTIVATE)">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_refund" name="Issue refund to wallet (R-REFUND)">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_charge" name="Chargeback reconciliation (R-CHARGEBACK)">
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="f0" sourceRef="s0" targetRef="t_view" />
    <bpmn:sequenceFlow id="f1" sourceRef="t_view" targetRef="t_pay" />
    <bpmn:sequenceFlow id="f2" sourceRef="t_pay" targetRef="g_pay" />
    <bpmn:sequenceFlow id="f3" name="yes" sourceRef="g_pay" targetRef="t_active" />
    <bpmn:sequenceFlow id="f4" name="no" sourceRef="g_pay" targetRef="r_payretry" />
    <bpmn:sequenceFlow id="f5" name="success" sourceRef="r_payretry" targetRef="t_active" />
    <bpmn:sequenceFlow id="f6" name="final fail" sourceRef="r_payretry" targetRef="e_nosub" />
    <bpmn:sequenceFlow id="f7" sourceRef="t_active" targetRef="g_renew" />
    <bpmn:sequenceFlow id="f8" name="charged" sourceRef="g_renew" targetRef="e_active" />
    <bpmn:sequenceFlow id="f9" name="failed -&gt; past_due" sourceRef="g_renew" targetRef="r_dunning" />
    <bpmn:sequenceFlow id="f10" sourceRef="r_dunning" targetRef="g_grace" />
    <bpmn:sequenceFlow id="f11" name="paid" sourceRef="g_grace" targetRef="t_active" />
    <bpmn:sequenceFlow id="f12" name="grace elapsed -&gt; expired" sourceRef="g_grace" targetRef="r_react" />
    <bpmn:sequenceFlow id="f13" name="resubscribed" sourceRef="r_react" targetRef="t_active" />
    <bpmn:sequenceFlow id="f14" name="cancel" sourceRef="t_active" targetRef="t_cancel" />
    <bpmn:sequenceFlow id="f15" sourceRef="t_cancel" targetRef="e_ended" />
    <bpmn:sequenceFlow id="f16" name="refund owed" sourceRef="t_active" targetRef="r_refund" />
    <bpmn:sequenceFlow id="f17" name="settled" sourceRef="r_refund" targetRef="e_active" />
    <bpmn:sequenceFlow id="f18" name="refund failed" sourceRef="r_refund" targetRef="r_charge" />
    <bpmn:sequenceFlow id="f19" sourceRef="r_charge" targetRef="e_active" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dg_J-SUBSCRIBE"><bpmndi:BPMNPlane id="Pl_J-SUBSCRIBE" bpmnElement="Collab_J-SUBSCRIBE">
    <bpmndi:BPMNShape id="Pool_J-SUBSCRIBE_di" bpmnElement="Pool_J-SUBSCRIBE" isHorizontal="true"><dc:Bounds x="150" y="50" width="1940" height="640" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-SUBSCRIBE_Patient_di" bpmnElement="Lane_J-SUBSCRIBE_Patient" isHorizontal="true"><dc:Bounds x="180" y="60" width="1910" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-SUBSCRIBE_Finance___Ops_di" bpmnElement="Lane_J-SUBSCRIBE_Finance___Ops" isHorizontal="true"><dc:Bounds x="180" y="360" width="1910" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="s0_di" bpmnElement="s0"><dc:Bounds x="240" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_view_di" bpmnElement="t_view"><dc:Bounds x="440" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_pay_di" bpmnElement="t_pay"><dc:Bounds x="640" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_pay_di" bpmnElement="g_pay"><dc:Bounds x="840" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_active_di" bpmnElement="t_active"><dc:Bounds x="1040" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_renew_di" bpmnElement="g_renew"><dc:Bounds x="1440" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_active_di" bpmnElement="e_active"><dc:Bounds x="1640" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_payretry_di" bpmnElement="r_payretry"><dc:Bounds x="840" y="220" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_nosub_di" bpmnElement="e_nosub"><dc:Bounds x="840" y="319" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_cancel_di" bpmnElement="t_cancel"><dc:Bounds x="1040" y="220" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_ended_di" bpmnElement="e_ended"><dc:Bounds x="1040" y="319" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_dunning_di" bpmnElement="r_dunning"><dc:Bounds x="1440" y="520" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_grace_di" bpmnElement="g_grace"><dc:Bounds x="1640" y="527" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_react_di" bpmnElement="r_react"><dc:Bounds x="1840" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_refund_di" bpmnElement="r_refund"><dc:Bounds x="1240" y="520" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_charge_di" bpmnElement="r_charge"><dc:Bounds x="1240" y="605" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="f0_di" bpmnElement="f0"><di:waypoint x="276" y="147" /><di:waypoint x="440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1"><di:waypoint x="610" y="147" /><di:waypoint x="640" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2"><di:waypoint x="810" y="147" /><di:waypoint x="840" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3"><di:waypoint x="890" y="147" /><di:waypoint x="1040" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4"><di:waypoint x="865" y="172" /><di:waypoint x="925" y="220" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5"><di:waypoint x="925" y="220" /><di:waypoint x="1125" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6"><di:waypoint x="925" y="284" /><di:waypoint x="858" y="319" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7"><di:waypoint x="1210" y="147" /><di:waypoint x="1440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8"><di:waypoint x="1490" y="147" /><di:waypoint x="1640" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9"><di:waypoint x="1465" y="172" /><di:waypoint x="1525" y="520" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10"><di:waypoint x="1610" y="552" /><di:waypoint x="1640" y="552" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11"><di:waypoint x="1665" y="527" /><di:waypoint x="1125" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12"><di:waypoint x="1665" y="527" /><di:waypoint x="1925" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13"><di:waypoint x="2010" y="147" /><di:waypoint x="1040" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f14_di" bpmnElement="f14"><di:waypoint x="1125" y="179" /><di:waypoint x="1125" y="220" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f15_di" bpmnElement="f15"><di:waypoint x="1125" y="284" /><di:waypoint x="1058" y="319" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f16_di" bpmnElement="f16"><di:waypoint x="1125" y="179" /><di:waypoint x="1325" y="520" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f17_di" bpmnElement="f17"><di:waypoint x="1325" y="520" /><di:waypoint x="1658" y="165" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f18_di" bpmnElement="f18"><di:waypoint x="1325" y="584" /><di:waypoint x="1325" y="605" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f19_di" bpmnElement="f19"><di:waypoint x="1325" y="605" /><di:waypoint x="1658" y="165" /></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>