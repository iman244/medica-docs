<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://medica/bpmn" id="DEF_P3_home_visit_fulfillment"><bpmn:collaboration id="C_P3_home_visit_fulfillment"><bpmn:participant id="PT_P3_home_visit_fulfillment" name="Home-Visit Fulfillment" processRef="PR_P3_home_visit_fulfillment" /></bpmn:collaboration><bpmn:process id="PR_P3_home_visit_fulfillment" isExecutable="false"><bpmn:laneSet id="LS_P3_home_visit_fulfillment"><bpmn:lane id="sys" name="System"><bpmn:flowNodeRef>s</bpmn:flowNodeRef><bpmn:flowNodeRef>ord</bpmn:flowNodeRef><bpmn:flowNodeRef>assign</bpmn:flowNodeRef><bpmn:flowNodeRef>settle</bpmn:flowNodeRef><bpmn:flowNodeRef>e</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="phm" name="Pharmacy Hub"><bpmn:flowNodeRef>pick</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="nur" name="Nurse"><bpmn:flowNodeRef>travel</bpmn:flowNodeRef><bpmn:flowNodeRef>visit</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="pat" name="Patient"><bpmn:flowNodeRef>recv</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="s" name="Dose due / Rx active"><bpmn:outgoing>F_s_ord</bpmn:outgoing></bpmn:startEvent><bpmn:serviceTask id="ord" name="Create dose order + smart route (STEP-5-01)"><bpmn:incoming>F_s_ord</bpmn:incoming><bpmn:outgoing>F_ord_pick</bpmn:outgoing></bpmn:serviceTask><bpmn:userTask id="pick" name="Pick · pack · cold-chain log (STEP-5-03)"><bpmn:incoming>F_ord_pick</bpmn:incoming><bpmn:outgoing>F_pick_assign</bpmn:outgoing></bpmn:userTask><bpmn:serviceTask id="assign" name="Assign nurse + schedule (STEP-4A-01)"><bpmn:incoming>F_pick_assign</bpmn:incoming><bpmn:outgoing>F_assign_travel</bpmn:outgoing></bpmn:serviceTask><bpmn:userTask id="travel" name="Travel to patient"><bpmn:incoming>F_assign_travel</bpmn:incoming><bpmn:outgoing>F_travel_visit</bpmn:outgoing></bpmn:userTask><bpmn: