<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_J-DISPENSE" targetNamespace="http://medica/flows">
  <bpmn:collaboration id="Collab_J-DISPENSE"><bpmn:participant id="Pool_J-DISPENSE" name="Pharmacy → Nurse Medicine Handoff (J-DISPENSE)" processRef="Proc_J-DISPENSE" /></bpmn:collaboration>
  <bpmn:process id="Proc_J-DISPENSE" isExecutable="false">
    <bpmn:laneSet id="LS_J-DISPENSE">
      <bpmn:lane id="Lane_J-DISPENSE_Pharmacy" name="Pharmacy">
        <bpmn:flowNodeRef>s0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_scan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_bar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_stock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_record</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_stock</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-DISPENSE_Nurse" name="Nurse">
        <bpmn:flowNodeRef>t_sign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t_inv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g_count</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>r_count</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_J-DISPENSE_Ops" name="Ops">
        <bpmn:flowNodeRef>t_ops</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>e_resched</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="s0" name="Dose order ready for pickup">
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t_scan" name="Scan vial barcode (PH-A.H5)">
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_bar" name="Barcode OK?">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="g_stock" name="In stock?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t_sign" name="Nurse verifies &amp; signs receipt (PH-A.H5)">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_record" name="Record dispense — vial → dispensed (API-PHARM-004)">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_inv" name="Nurse records inventory + cold-chain bag log (NF-C.H3)">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g_count" name="Count matches?">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e_done" name="Vial in nurse custody — ready for visit">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:incoming>f14</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_manual" name="Manual entry + verify (R-MANUAL-ENTRY)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="r_stock" name="Stock-out — restock / substitute (R-STOCKOUT)">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t_ops" name="Source stock or reschedule pickup">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e_resched" name="Pickup rescheduled">
      <bpmn:incoming>f8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="r_count" name="Reconcile count / raise restock (R-STOCKOUT)">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="f0" sourceRef="s0" targetRef="t_scan" />
    <bpmn:sequenceFlow id="f1" sourceRef="t_scan" targetRef="g_bar" />
    <bpmn:sequenceFlow id="f2" name="scans ok" sourceRef="g_bar" targetRef="g_stock" />
    <bpmn:sequenceFlow id="f3" name="scan fails" sourceRef="g_bar" targetRef="r_manual" />
    <bpmn:sequenceFlow id="f4" sourceRef="r_manual" targetRef="g_stock" />
    <bpmn:sequenceFlow id="f5" name="in stock" sourceRef="g_stock" targetRef="t_sign" />
    <bpmn:sequenceFlow id="f6" name="out of stock" sourceRef="g_stock" targetRef="r_stock" />
    <bpmn:sequenceFlow id="f7" sourceRef="r_stock" targetRef="t_ops" />
    <bpmn:sequenceFlow id="f8" sourceRef="t_ops" targetRef="e_resched" />
    <bpmn:sequenceFlow id="f9" sourceRef="t_sign" targetRef="t_record" />
    <bpmn:sequenceFlow id="f10" sourceRef="t_record" targetRef="t_inv" />
    <bpmn:sequenceFlow id="f11" sourceRef="t_inv" targetRef="g_count" />
    <bpmn:sequenceFlow id="f12" name="matches" sourceRef="g_count" targetRef="e_done" />
    <bpmn:sequenceFlow id="f13" name="mismatch" sourceRef="g_count" targetRef="r_count" />
    <bpmn:sequenceFlow id="f14" name="reconciled" sourceRef="r_count" targetRef="e_done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Dg_J-DISPENSE"><bpmndi:BPMNPlane id="Pl_J-DISPENSE" bpmnElement="Collab_J-DISPENSE">
    <bpmndi:BPMNShape id="Pool_J-DISPENSE_di" bpmnElement="Pool_J-DISPENSE" isHorizontal="true"><dc:Bounds x="150" y="50" width="1806" height="940" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-DISPENSE_Pharmacy_di" bpmnElement="Lane_J-DISPENSE_Pharmacy" isHorizontal="true"><dc:Bounds x="180" y="60" width="1776" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-DISPENSE_Nurse_di" bpmnElement="Lane_J-DISPENSE_Nurse" isHorizontal="true"><dc:Bounds x="180" y="360" width="1776" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Lane_J-DISPENSE_Ops_di" bpmnElement="Lane_J-DISPENSE_Ops" isHorizontal="true"><dc:Bounds x="180" y="660" width="1776" height="300" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="s0_di" bpmnElement="s0"><dc:Bounds x="240" y="129" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_scan_di" bpmnElement="t_scan"><dc:Bounds x="440" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_bar_di" bpmnElement="g_bar"><dc:Bounds x="640" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_stock_di" bpmnElement="g_stock"><dc:Bounds x="840" y="122" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_sign_di" bpmnElement="t_sign"><dc:Bounds x="1040" y="415" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_record_di" bpmnElement="t_record"><dc:Bounds x="1240" y="115" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_inv_di" bpmnElement="t_inv"><dc:Bounds x="1440" y="415" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="g_count_di" bpmnElement="g_count"><dc:Bounds x="1640" y="422" width="50" height="50" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_done_di" bpmnElement="e_done"><dc:Bounds x="1840" y="429" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_manual_di" bpmnElement="r_manual"><dc:Bounds x="640" y="220" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_stock_di" bpmnElement="r_stock"><dc:Bounds x="840" y="220" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="t_ops_di" bpmnElement="t_ops"><dc:Bounds x="840" y="715" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="e_resched_di" bpmnElement="e_resched"><dc:Bounds x="1040" y="729" width="36" height="36" /></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="r_count_di" bpmnElement="r_count"><dc:Bounds x="1640" y="520" width="170" height="64" /></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="f0_di" bpmnElement="f0"><di:waypoint x="276" y="147" /><di:waypoint x="440" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1"><di:waypoint x="610" y="147" /><di:waypoint x="640" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2"><di:waypoint x="690" y="147" /><di:waypoint x="840" y="147" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3"><di:waypoint x="665" y="172" /><di:waypoint x="725" y="220" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4"><di:waypoint x="725" y="220" /><di:waypoint x="865" y="172" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5"><di:waypoint x="865" y="172" /><di:waypoint x="1125" y="415" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6"><di:waypoint x="865" y="172" /><di:waypoint x="925" y="220" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7"><di:waypoint x="925" y="284" /><di:waypoint x="925" y="715" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8"><di:waypoint x="1010" y="747" /><di:waypoint x="1040" y="747" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9"><di:waypoint x="1125" y="415" /><di:waypoint x="1325" y="179" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10"><di:waypoint x="1325" y="179" /><di:waypoint x="1525" y="415" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11"><di:waypoint x="1610" y="447" /><di:waypoint x="1640" y="447" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12"><di:waypoint x="1690" y="447" /><di:waypoint x="1840" y="447" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13"><di:waypoint x="1665" y="472" /><di:waypoint x="1725" y="520" /></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="f14_di" bpmnElement="f14"><di:waypoint x="1725" y="520" /><di:waypoint x="1858" y="465" /></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>